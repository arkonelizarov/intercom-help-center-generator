{
  "name": "intercom-docs-publisher",
  "version": "1.0.0",
  "description": "Drop-in template: write docs in Markdown, publish to Intercom Articles. Works with any product.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "fetch-sources": "tsx scripts/fetch-sources.ts",
    "validate": "tsx scripts/validate-docs.ts",
    "publish": "tsx scripts/publish-intercom.ts",
    "publish:dry": "tsx scripts/publish-intercom.ts --dry-run"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "marked": "^12.0.0",
    "yaml": "^2.4.0"
  }
}
