# Copy this file to .env and fill in real values. .env is gitignored.

# ── Intercom ──────────────────────────────────────────────────────────────────

# Intercom Developer Hub → your app → Authentication → Access token
INTERCOM_TOKEN=tok:...

# Region of your Intercom workspace: us | eu | au
INTERCOM_REGION=us

# Admin ID that articles are published under.
# Find it: GET https://api.intercom.io/admins  (or check the Intercom URL when viewing your profile)
INTERCOM_ADMIN_ID=
